{
  "compilerOptions": {
    "target": "ESNext",
    "module": "node16",
    "lib": ["ESNext", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["main.ts", "preload.ts", "src/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "renderer.ts"]
}
