{
  "name": "pocket-planner",
  "version": "1.8.0",
  "description": "A simple weekly planning desktop app",
  "author": "Estian Yssel",
  "main": "dist/main.js",
  "scripts": {
    "build:ts": "node build.mjs",
    "watch": "node build.mjs --watch",
    "type-check": "tsc --noEmit",
    "start": "npm.cmd run build:ts && electron .",
    "start:seed": "npm.cmd run build:ts && node dist/scripts/seed-test-data.js && electron .",
    "start:clean": "npm.cmd run build:ts && node dist/scripts/clean-dev-data.js && electron .",
    "build": "npm.cmd run build:ts && electron-builder --win",
    "build:mac": "node build.mjs && electron-builder --mac",
    "seed": "node dist/scripts/seed-test-data.js",
    "clean": "node dist/scripts/clean-dev-data.js",
    "test": "jest",
    "release": "standard-version --skip.commit --skip.tag"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.estianyssel.pocket-planner",
    "productName": "Pocket Planner",
    "publish": {
      "provider": "github"
    },
    "files": [
      "dist/**/*",
      "index.html",
      "styles.css",
      "icon.png",
      "icon.ico",
      "icon.icns",
      "CHANGELOG.md",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  }
}
